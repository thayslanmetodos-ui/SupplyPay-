rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - email: string (required, email format)
    //   - name: string (required)
    //   - role: string (required, ['operator', 'supplier', 'admin'])
    //   - cpf: string (optional)
    //   - bank: string (optional)
    //   - whatsapp: string (optional)
    //   - status: string (optional, ['ON', 'OFF'])
    //   - balance: number (required)
    //   - level_points: number (required)
    //   - is_blocked: bool (required)
    //   - is_approved: bool (required)
    //   - created_at: timestamp (required)
    //
    // Collection: transactions
    // Fields:
    //   - operator_id: string (required)
    //   - supplier_id: string (required)
    //   - amount: number (required)
    //   - status: string (required, ['PENDING', 'IN_USE', 'COMPLETED', 'FAILED'])
    //   - created_at: timestamp (required)
    //
    // Collection: notifications
    // Fields:
    //   - uid: string (required)
    //   - message: string (required)
    //   - type: string (required)
    //   - created_at: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "suportethayslanbssns@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'name', 'role', 'balance', 'level_points', 'is_blocked', 'is_approved']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.role in ['operator', 'supplier', 'admin'] &&
             data.balance is number &&
             data.level_points is number &&
             data.is_blocked is bool &&
             data.is_approved is bool;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                      (isOwner(userId) && request.resource.data.role != 'admin' || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                      (isOwner(userId) && 
                       request.resource.data.role == resource.data.role && 
                       request.resource.data.is_approved == resource.data.is_approved &&
                       request.resource.data.is_blocked == resource.data.is_blocked &&
                       request.resource.data.balance == resource.data.balance &&
                       request.resource.data.level_points == resource.data.level_points
                       || isAdmin());
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (
        resource.data.operator_id == request.auth.uid || 
        resource.data.supplier_id == request.auth.uid || 
        isAdmin()
      );
      allow create: if isAuthenticated() && (
        request.resource.data.operator_id == request.auth.uid || isAdmin()
      );
      allow update: if isAuthenticated() && (
        resource.data.operator_id == request.auth.uid || 
        resource.data.supplier_id == request.auth.uid || 
        isAdmin()
      );
    }

    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow create: if isAuthenticated(); // Operators can notify suppliers
      allow update: if isOwner(resource.data.uid) || isAdmin();
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
