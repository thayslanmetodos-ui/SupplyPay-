{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended user information stored in Firestore",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["operator", "supplier", "admin"] },
        "cpf": { "type": "string" },
        "bank": { "type": "string" },
        "whatsapp": { "type": "string" },
        "status": { "type": "string", "enum": ["ON", "OFF"] },
        "balance": { "type": "number" },
        "level_points": { "type": "number" },
        "is_blocked": { "type": "boolean" },
        "is_approved": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "name"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction record",
      "type": "object",
      "properties": {
        "operator_id": { "type": "string" },
        "supplier_id": { "type": "string" },
        "amount": { "type": "number" },
        "supplier_fee": { "type": "number" },
        "status": { "type": "string", "enum": ["PENDING", "IN_USE", "COMPLETED", "FAILED"] },
        "withdrawal_amount": { "type": "number" },
        "pix_key": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "operator_name": { "type": "string" },
        "supplier_name": { "type": "string" }
      },
      "required": ["operator_id", "supplier_id", "amount", "status", "created_at"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["PURCHASE", "WITHDRAWAL_COMPLETED", "WITHDRAWAL_FAILED", "SYSTEM"] },
        "transactionId": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      },
      "required": ["uid", "message", "type", "created_at"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Transaction records"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    }
  }
}
